# Optional advanced-user settings.
# Normal users can skip this file and use `memrunner ui` instead.
# Environment variables override dashboard settings.

MEMRISE_COURSE_ID= # raw ID or full copied course URL
MEMRISE_EMAIL=
MEMRISE_PASSWORD=
MEMRUNNER_SOURCE_LABEL=source
MEMRUNNER_TARGET_LABEL=target
MEMRUNNER_DB_PATH=memrunner_vocab.sqlite3
MEMRUNNER_HEADLESS=false
MEMRUNNER_MUTE_AUDIO=true
MEMRUNNER_ACTION_DELAY_S=0.04
MEMRUNNER_IDLE_TIMEOUT_S=3.0
